{
  "name": "blfsc-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check": "npm run portal:check-markup && npm run format:check && npm run lint && npm run typecheck && npm run test:unit",
    "verify:push": "npm run check && npm audit --omit=dev --audit-level=high",
    "build": "node scripts/clear-next-build-lock.mjs && next build --webpack",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "dev": "next dev",
    "dev:ci": "next dev --port 3100",
    "start": "next start",
    "start:ci": "next start --port 3100",
    "portal:sync-markup": "node scripts/generate-portal-markup.mjs",
    "portal:check-markup": "node scripts/generate-portal-markup.mjs --check",
    "verify:supabase-env": "node scripts/verify-supabase-env.mjs",
    "verify:invite-chain": "node scripts/verify-portal-invite-chain.mjs",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "cross-env RUN_A11Y_TESTS=true playwright test tests/e2e/accessibility.spec.ts",
    "test:e2e:prod-smoke": "cross-env PLAYWRIGHT_BASE_URL=https://blfsc.com playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lighthouse:ci": "node scripts/run-lighthouse-ci.mjs",
    "quality:ci": "npm run build && cross-env PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100 LHCI_BASE_URL=http://127.0.0.1:3100 start-server-and-test \"npm run start:ci\" http://127.0.0.1:3100 \"npm run test:e2e && npm run lighthouse:ci\"",
    "audit:production": "node scripts/audit-production.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run portal:check-markup && npm run verify:supabase-env && npm run verify:invite-chain && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "git:login": "node scripts/npm-git-login.mjs",
    "git:web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/gh-web.ps1",
    "git:publish": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/git-first-push.ps1",
    "git:publish:force": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/git-first-push.ps1 -Force"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,css,md,json,html,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@sentry/nextjs": "^10.46.0",
    "@supabase/supabase-js": "^2.57.4",
    "next": "16.2.1",
    "posthog-js": "^1.364.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "chrome-launcher": "^1.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^3.0.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
