# Public site URL
NEXT_PUBLIC_SITE_URL=https://blfsc.com

# --- Build-time public Supabase (required for production builds / OpenNext + Workers) ---
# These are embedded in the client bundle at `next build` time via src/lib/site-config.ts.
# Before `npm run deploy`, run `npm run verify:supabase-env` so the URL matches `supabase link`,
# and confirm keys in Supabase Dashboard → Settings → API (publishable key, not service_role).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (Next app)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# PostHog (Next app)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional contact delivery via Resend
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Supabase Edge Function `order-notify` (set in Dashboard → Edge Functions → Secrets, not in Next)
# Reuses RESEND_API_KEY + BROADCAST_FROM_EMAIL from broadcast setup, or SMTP_* fallback.
# ORDER_NOTIFY_TO_EMAIL=ops@example.com,second@example.com
# PUBLIC_PORTAL_URL=https://blfsc.com/portal

# Optional bot protection for contact form
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Required for shared server-side contact rate limiting
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional CSP rollout toggle (set true to run report-only mode temporarily)
CSP_REPORT_ONLY=false

# Optional: allow Cloudflare Web Analytics beacon in CSP (script + connect to cloudflareinsights.com)
# CSP_ALLOW_CLOUDFLARE_INSIGHTS=true

# Production audit: unskip Cloudflare API checks in scripts/audit-production.mjs
# npm run audit:production loads .env then .env.local — put secrets in .env.local (gitignored).
# Locally you can omit these if `wrangler login` is active (OAuth token read from ~/.wrangler).
# (Optional: same names as GitHub repo secrets for .github/workflows/prod-smoke.yml audit job.)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# Optional overrides for audit script defaults:
# BLFSC_SITE_URL=https://blfsc.com
# BLFSC_PAGES_URL=https://blfsc.pages.dev
# BLFSC_LEGACY_PAGES_PROJECT=blfsc
# BLFSC_LEGACY_WORKER=blfsc-phase1-preview
