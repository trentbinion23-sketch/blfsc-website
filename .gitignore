# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/.lighthouseci

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.cursor/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets (.env.example is whitelisted below).
# Broad rules + explicit names so audits and reviewers see the intent clearly.
.env*
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OpenNext
.open-next

# wrangler files
.wrangler
wrangler.toml
.dev.vars*
.dev.vars
!.dev.vars.example
!.env.example

# Supabase CLI local metadata (may contain project URLs)
supabase/.temp/
