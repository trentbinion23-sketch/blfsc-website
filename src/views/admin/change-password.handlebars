<div class="page-header">
  <h2>Change Password</h2>
  <p>Update your account password. Choose something strong and unique.</p>
</div>

{{#if error}}
<div class="alert alert-error">{{error}}</div>
{{/if}}
{{#if success}}
<div class="alert alert-success">{{success}}</div>
{{/if}}

<div class="card" style="max-width: 480px;">
  <form method="POST" action="/admin/change-password" novalidate autocomplete="off">
    <div class="form-group">
      <label for="current_password">Current Password</label>
      <input type="password" id="current_password" name="current_password" required autocomplete="current-password" />
    </div>
    <div class="form-group">
      <label for="new_password">New Password</label>
      <input type="password" id="new_password" name="new_password" required minlength="8" autocomplete="new-password" placeholder="Min 8 characters" />
    </div>
    <div class="form-group">
      <label for="confirm_password">Confirm New Password</label>
      <input type="password" id="confirm_password" name="confirm_password" required autocomplete="new-password" />
    </div>
    <div style="margin-top:1.5rem;">
      <button type="submit" class="btn btn-primary">Update Password</button>
    </div>
  </form>
</div>
